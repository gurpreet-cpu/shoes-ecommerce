# ── App ───────────────────────────────────────────────────────────────────────
# Set to 'production' on Railway/Render, 'development' locally
NODE_ENV=
# Port the Express server listens on (Railway auto-assigns, default 5000)
PORT=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string — get from Atlas > Connect > Drivers
MONGODB_URI=

# ── JWT ───────────────────────────────────────────────────────────────────────
# At least 64 random chars — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
# Different from access secret — same length requirement
JWT_REFRESH_SECRET=
# Access token TTL (short-lived) — e.g. 15m
JWT_ACCESS_EXPIRES=
# Refresh token TTL (long-lived) — e.g. 7d
JWT_REFRESH_EXPIRES=

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get all three from Cloudinary Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Paytm ─────────────────────────────────────────────────────────────────────
# Merchant ID — from Paytm Dashboard
PAYTM_MID=
# Merchant Key — NEVER share or commit this value
PAYTM_MERCHANT_KEY=
# WEBSTAGING for test accounts, WEBPROD for live
PAYTM_WEBSITE=
# Always WEB for web integration
PAYTM_CHANNEL_ID=
# Always Retail for ecommerce
PAYTM_INDUSTRY_TYPE=
# Full URL Paytm will POST payment result to — must be publicly reachable
PAYTM_CALLBACK_URL=

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
# Gmail address used to send emails
EMAIL_USER=
# Gmail App Password (16 chars) — NOT your real Gmail password
# Enable at: Google Account > Security > 2-Step Verification > App passwords
EMAIL_PASS=
# Display name + address in the From header, e.g: "Shoe Store <store@gmail.com>"
EMAIL_FROM=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Full URL of the React frontend — used for CORS and email links
# e.g. https://yourstore.vercel.app  (or http://localhost:5173 in dev)
CLIENT_URL=

# ── Seed / Admin ──────────────────────────────────────────────────────────────
# Initial admin account credentials used by the seed script
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Admin Notifications ────────────────────────────────────────────────────────
# Primary admin email — receives all order/stock/user notifications
# e.g. gurpreetjoey@gmail.com
ADMIN_EMAIL=
# Secondary admin email (optional) — receives the same notifications
ADMIN_EMAIL_2=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The callback URL registered in Google Cloud Console
# Dev:  http://localhost:5000/api/auth/google/callback
# Prod: https://your-api.railway.app/api/auth/google/callback
GOOGLE_CALLBACK_URL=
# 64 random hex chars — generate with: openssl rand -hex 64
SESSION_SECRET=




